# Deny by default, then allow the audit-oriented source release.
*

!.gitignore
!LICENSE
!README.md
!requirements.txt

!analysis/
!analysis/*.py

!fixtures/
!fixtures/*.txt

!models/
!models/*.placeholder
!models/README.md

# Runtime, generated, deployment, and large artifact exclusions.
.venv/
node_modules/
dist/
src/
server/
*.sqlite
*.sqlite-*
*.db
*.vec
*.vec.gz
*.zip
*.tar
*.tgz
*.pdf
*.png
__pycache__/
*.pyc
.DS_Store
._*
